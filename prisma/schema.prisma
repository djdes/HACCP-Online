generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                       String                     @id @default(cuid())
  name                     String
  type                     String
  inn                      String?
  address                  String?
  phone                    String?
  subscriptionPlan         String                     @default("trial")
  subscriptionEnd          DateTime?
  locale                   String                     @default("ru")
  brandColor               String?
  logoUrl                  String?
  yookassaShopId           String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  /// Per-organisation bearer token for POST /api/external/entries. When set,
  /// overrides the shared EXTERNAL_API_TOKEN env and resolves the caller's
  /// organizationId automatically. Keep unique across orgs.
  externalApiToken         String?                    @unique
  /// Journal template codes the organization has chosen NOT to keep. Empty
  /// by default (= all 35 journals enabled). Toggled from /settings/journals
  /// so different production profiles (кафе, мясокомбинат, пекарня…) can
  /// hide the journals that don't apply. Disabled journals are muted in
  /// the browser and excluded from dashboard compliance counts.
  disabledJournalCodes     Json                       @default("[]")
  /// Journal template codes enabled for auto document creation. Every
  /// day a cron checks for codes in this list and ensures there is an
  /// active JournalDocument covering today; creates a month-long doc if
  /// missing. Manages via /settings/auto-journals.
  autoJournalCodes         Json                       @default("[]")
  /// Compliance toggle: when true, a previously-completed journal task
  /// can ONLY be re-opened for edit by management roles
  /// (manager/head_chef/owner/technologist) or ROOT. Default false —
  /// any user who originally filled a task is allowed to re-open and
  /// correct it. Toggled from /settings/compliance.
  requireAdminForJournalEdit Boolean                  @default(false)
  /// Час суток (0-23 по локальному часовому поясу организации) когда
  /// смена заканчивается и cron auto-close срабатывает на shared-задачах
  /// без записей. По умолчанию 0 = полночь (23:59:59). Для ночных смен
  /// можно поставить, например, 6 — тогда «сегодня» длится до 06:00.
  shiftEndHour       Int                        @default(0)
  /// Compliance toggle: «закрытый день». Когда true — после `shiftEndHour`
  /// рядовые сотрудники не могут редактировать записи прошедших дней
  /// (PUT/PATCH/DELETE на JournalDocumentEntry). Только management
  /// (manager/head_chef/owner/technologist/root) может «приоткрыть»
  /// прошлый день — каждое такое редактирование пишется в AuditLog с
  /// reason. Для ХАССП — гарантирует, что официант не «допишет»
  /// вчерашний контроль t° задним числом.
  lockPastDayEdits   Boolean                    @default(false)
  /// Сколько сообщений к AI-чату осталось в этом месяце. Декремент
  /// в /api/ai/sanpin-chat и /api/ai/period-report. Сброс — cron
  /// /api/cron/reset-ai-quota 1-го числа. Default 20 — trial-tier.
  /// Pro тарифы могут установить большое значение (10000) или −1
  /// (трактуем как unlimited).
  aiMonthlyMessagesLeft Int                     @default(20)
  /// Базовый месячный лимит — куда возвращаемся после reset cron'а.
  /// Тариф Pro меняет это поле, не aiMonthlyMessagesLeft.
  aiMonthlyQuota     Int                        @default(20)
  /// OAuth-токен Yandex.Disk REST API (получается через /authorize). Если
  /// заполнен — еженедельный cron /api/cron/yandex-backup сохраняет туда
  /// JSON-дамп всех журналов за последние 7 дней. Хранится в открытом
  /// виде, потому что ресторатор сам выпускает app-token для нашего
  /// приложения и может его отозвать в любой момент через
  /// https://oauth.yandex.ru/client/applications.
  yandexDiskToken          String?
  /// Папка на Я.Диске куда писать бэкапы. По умолчанию /WeSetup.
  yandexDiskFolder         String                     @default("/WeSetup")
  /// Когда последний раз cron успешно загрузил дамп. Используем чтобы
  /// показать в /settings/backup карточке «последний бэкап: …» и в
  /// /dashboard health-check'е сигналить если бэкап старше 14 дней.
  yandexDiskLastBackupAt   DateTime?
  /// Email бухгалтера для еженедельной выгрузки списаний (LossRecord)
  /// в формате CSV под импорт в 1С:Бухгалтерия. Дёргается cron
  /// `/api/cron/losses-export-1c` по понедельникам. Если null —
  /// org не получает рассылку.
  accountantEmail          String?
  /// IANA timezone для отображения дат и расчётов compliance.
  /// Default "Europe/Moscow" (UTC+3) — большинство клиентов в РФ.
  /// Используется для перевода дашборд/отчётов из UTC в локаль.
  /// Не путать с `shiftEndHour` — тот про границу смены, а это
  /// про общую локализацию интерфейса.
  timezone                 String                     @default("Europe/Moscow")
  users                    User[]
  areas                    Area[]
  journalEntries           JournalEntry[]
  products                 Product[]
  auditLogs                AuditLog[]
  managerScopes            ManagerScope[]
  batches                  Batch[]
  capaTickets              CapaTicket[]
  lossRecords              LossRecord[]
  productionPlans          ProductionPlan[]
  changeRequests           ChangeRequest[]
  staffCompetencies        StaffCompetency[]
  journalDocuments         JournalDocument[]
  jobPositions             JobPosition[]
  notifications            Notification[]
  botInviteTokens          BotInviteToken[]
  journalObligations       JournalObligation[]
  workShifts               WorkShift[]
  jobPositionJournalAccess JobPositionJournalAccess[]
  bonusEntries             BonusEntry[]
  inspectorTokens          InspectorToken[]
  journalCloseEvents       JournalCloseEvent[]
  formFillTimings          FormFillTiming[]
}

model User {
  id                          String                   @id @default(cuid())
  email                       String                   @unique
  name                        String
  phone                       String?
  passwordHash                String
  role                        String                   @default("cook")
  // Free-form job title that overrides the role-based label in journals.
  // Lets the same "cook" role user be displayed as "Повар холодного цеха" or
  // "Официант" per employee, instead of flipping between journals.
  positionTitle               String?
  organizationId              String
  organization                Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  telegramChatId              String?
  notificationPrefs           Json?
  isActive                    Boolean                  @default(true)
  // Platform-level superadmin flag. Orthogonal to `role` (which is the in-org
  // job title). Root users still belong to a real `Organization`; the synthetic
  // "platform" org carries them so every existing FK/query keeps working.
  isRoot                      Boolean                  @default(false)
  // False until the owner has explicitly edited this user's journal ACL in
  // /settings/users. While false, `hasJournalAccess` grants all journals —
  // this gives zero-regression behaviour for employees predating the ACL.
  journalAccessMigrated       Boolean                  @default(false)
  // Soft-archive marker for the staff page. When set, the user disappears
  // from active lists + can no longer log in, but stays referenced by old
  // journal entries. Separate from `isActive` so the staff screen can
  // distinguish "uploaded an employee but disabled them" from "formally
  // dismissed / transferred to archive".
  archivedAt                  DateTime?
  // Structured job position reference. Optional — existing rows keep their
  // free-form `positionTitle` until the seed migration buckets them into
  // per-org `JobPosition` rows. New UI writes only `jobPositionId`; legacy
  // UI continues to read `positionTitle` via the getUserDisplayTitle helper.
  jobPositionId               String?
  jobPosition                 JobPosition?             @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  createdAt                   DateTime                 @default(now())
  /// Personal permission override — JSON-массив кодов из
  /// src/lib/permissions.ts. null = наследовать от должности/группы.
  /// Индивидуальный override используется редко: «этот конкретный
  /// официант умеет принимать поставки и его надо пустить в batches».
  permissionsJson             Json?
  /// User-chosen colour theme. "light" | "dark". Sourced once on each
  /// page-load (dashboard layout, Mini App layout) so the choice
  /// follows the user across devices. localStorage caches it for FOUC
  /// suppression but DB is source of truth.
  themePreference             String                   @default("light")
  journalEntries              JournalEntry[]
  journalAccess               UserJournalAccess[]
  inviteToken                 InviteToken?
  botInviteToken              BotInviteToken?
  workOffDays                 StaffWorkOffDay[]
  vacations                   StaffVacation[]
  sickLeaves                  StaffSickLeave[]
  dismissal                   StaffDismissal?
  notifications               Notification[]
  journalObligations          JournalObligation[]
  workShifts                  WorkShift[]
  entryAttachments            JournalEntryAttachment[]
  documentEntries             JournalDocumentEntry[]
  managerScopes               ManagerScope[]           @relation("ManagerScopes")
  defaultAssigneeForTemplates JournalTemplate[]        @relation("DefaultAssignee")
  bonusEntries                BonusEntry[]
  closedJournalEvents         JournalCloseEvent[]      @relation("ClosedBy")
  reopenedJournalEvents       JournalCloseEvent[]      @relation("ReopenedBy")
  formFillTimings             FormFillTiming[]

  @@index([organizationId, archivedAt])
  @@index([jobPositionId])
}

/// A custom job title (должность) an organisation has chosen to use.
/// `categoryKey` groups positions into the two columns from the staff page —
/// "management" (Руководство) and "staff" (Сотрудники). `sortOrder` lets the
/// owner drag positions around; unique (org, category, name) keeps duplicates
/// out.
model JobPosition {
  id              String                     @id @default(cuid())
  organizationId  String
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// "management" | "staff"
  categoryKey     String
  name            String
  sortOrder       Int                        @default(0)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  users           User[]
  workShifts      WorkShift[]
  /// JSON-массив permission-кодов (см. src/lib/permissions.ts). null =
  /// наследовать defaults группы (management/staff). Override для
  /// конкретной должности: «пекари тоже могут редактировать график».
  permissionsJson Json?
  journalAccess   JobPositionJournalAccess[]

  /// Список user.id, которых видят все сотрудники этой должности.
  /// Источник истины для:
  ///   • TasksFlow `users.managed_worker_ids` (через sync)
  ///   • Telegram-бот scope-фильтр (видимость других сотрудников)
  /// Пустой массив = «никого не видит» (только свои задачи). Если
  /// не задано (нет ManagerScope per-user тоже) — fallback на
  /// «видит всех» (back-compat). Редактируется через
  /// /settings/position-staff-visibility.
  visibleUserIds  String[]                   @default([])

  @@unique([organizationId, categoryKey, name])
  @@index([organizationId, sortOrder])
}

/// Hygiene-journal autofill input: a day the employee is off duty.
model StaffWorkOffDay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Day at 00:00 UTC — stored as DateTime for Prisma friendliness.
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

/// Vacation period (график отпусков) — inclusive on both ends.
model StaffVacation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateFrom  DateTime
  dateTo    DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([dateFrom, dateTo])
}

/// Sick-leave period (график больничных) — inclusive on both ends.
model StaffSickLeave {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateFrom  DateTime
  dateTo    DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([dateFrom, dateTo])
}

/// Formal dismissal record (график увольнений). Unique per user — a single
/// dismissal is enough; if the employee is re-hired, remove the row + unarchive.
model StaffDismissal {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@index([date])
}

/// Смена сотрудника — «кто сегодня на работе и в какой роли». Именно
/// эта таблица делает возможным «Назначить задачу на должность, а не на
/// Иванова»: сохраняем расписание на каждый день, потом резолвер находит
/// дежурного с нужной `jobPositionId` на целевую дату. Если строки на
/// день нет — сотрудник считается не запланированным (исключается из
/// автосзначений).
model WorkShift {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Якорь дня (UTC-midnight).
  date           DateTime
  /// На какой должности дежурит. Необязательно — fallback на jobPositionId
  /// пользователя из User.jobPositionId. Явно задаётся, если сотрудник
  /// сегодня подменяет другой пост (повар холодного цеха перекрывает
  /// горячий, например).
  jobPositionId  String?
  jobPosition    JobPosition? @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  /// scheduled | off | vacation | sick
  status         String       @default("scheduled")
  handoverNotes  String?
  handoverToId   String?
  handoverAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, date])
  @@index([organizationId, date])
  @@index([date, status])
}

/// Invite flow token. Created alongside a placeholder `User` when an owner
/// invites a new employee; mailed to them as /invite/<token> URL. The user
/// clicks, sets their password, and the token is marked `usedAt`.
///
/// `tokenHash` is a bcrypt/sha256 digest of the raw token — raw value never
/// persisted, so a DB leak cannot produce usable invite links.
model InviteToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
}

/// Invite tokens for the Telegram-first onboarding flow (Mini App Stage 1).
/// Separate from `InviteToken` because semantics differ: `InviteToken` means
/// "set a password on the site", this one means "bind your Telegram identity".
/// Consumed by the grammy `/start inv_<token>` handler, which resolves the
/// token, writes `telegramChatId` on the matching User and activates them.
/// Read-only access tokens for SES / Роспотребнадзор inspector visits.
/// Created by org admin via /settings/inspector-portal — produces a TTL'd
/// share-link. Inspector opens /inspector/<token>, sees journals + entries
/// for the configured period in read-only mode, can download PDF за период
/// одной кнопкой.
///
/// Period is fixed at creation (no «slide forward»). Notes optional —
/// admin может пометить «проверка СЭС 2026-04-30 / Иванова И.И.».
/// Like InviteToken — only sha256 digest is persisted, raw token is shown
/// once on creation.
model InspectorToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  /// Free-form description set by admin (visible only in their list).
  label          String?
  /// Period the inspector is allowed to view (UTC midnight).
  periodFrom     DateTime
  periodTo       DateTime
  expiresAt      DateTime
  /// Bumped on every successful resolve — UI shows last-access stamp.
  lastAccessedAt DateTime?
  /// Total resolve count for usage stats.
  accessCount    Int          @default(0)
  /// Once admin clicks «Отозвать», token stops working without removing
  /// the row (audit trail of who/when/why).
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  /// Who issued the token (admin's userId). Helps audits and "кто впустил
  /// инспектора" forensics. Nullable for legacy and ROOT-issued tokens.
  createdById    String?
  visits         InspectorVisit[]

  @@index([organizationId])
  @@index([expiresAt])
}

/// B6 — Электронная подпись инспектора. Каждый раз когда инспектор
/// нажимает «Подтверждаю просмотр» на /inspector/<token>, мы создаём
/// row с timestamp + IP + user-agent + список просмотренных templates.
/// На стороне админа в /settings/inspector-portal — badge «Подписал
/// 2026-04-30 14:30». Compliance-проверка постфактум: видно кто и
/// когда смотрел журналы.
model InspectorVisit {
  id           String         @id @default(cuid())
  tokenId      String
  token        InspectorToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  signedAt     DateTime       @default(now())
  ipAddress    String?
  userAgent    String?
  /// ФИО / должность которое инспектор сам указал в форме «Подтверждаю».
  inspectorName String?
  /// Список templateCodes которые он просмотрел в эту сессию.
  templatesViewed Json?

  @@index([tokenId])
}

/// Замер времени заполнения формы — «сколько секунд от open до submit».
/// Используется на ROOT-дашборде для UX-аналитики: какие формы тормозят
/// сотрудников, требуют упрощения. Платформенная метрика, в org UI не
/// показывается.
///
/// Запись создаётся в submit-handler'е task-fill / journal-documents
/// если client передал `openedAt` в payload. Старые клиенты без поля
/// просто не пишут timing — это OK.
model FormFillTiming {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId     String
  template       JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Длительность от open formы до submit'а в миллисекундах.
  durationMs     Int
  /// "task-fill" | "document-edit" | "field-form" — для разделения
  /// сценариев в аналитике.
  source         String          @default("task-fill")
  createdAt      DateTime        @default(now())

  @@index([templateId, createdAt])
  @@index([organizationId, createdAt])
}

model BotInviteToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([expiresAt])
}

/// Per-journal access grant for an employee. Rows only exist for explicit
/// grants; absence = no access (after `User.journalAccessMigrated` flips to
/// true). Managers / root bypass this table entirely.
model UserJournalAccess {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateCode String
  canRead      Boolean  @default(true)
  canWrite     Boolean  @default(true)
  canFinalize  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, templateCode])
  @@index([userId])
}

model Area {
  id             String         @id @default(cuid())
  name           String
  description    String?
  lat            Float?
  lng            Float?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipment      Equipment[]
  journalEntries JournalEntry[]
}

model Equipment {
  id             String                   @id @default(cuid())
  name           String
  type           String
  serialNumber   String?
  tempMin        Float?
  tempMax        Float?
  tuyaDeviceId   String?
  areaId         String
  area           Area                     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  sensorMappings EquipmentSensorMapping[]
}

/// Связь «датчик ↔ поле шаблона журнала». Один Tuya-девайс может
/// отдавать несколько метрик (`va_temperature`, `va_humidity`),
/// поэтому на один Equipment вешается N мапингов — по одному на
/// каждое поле, которое мы заполняем автоматически.
///
/// Используется только когда у соответствующего шаблона
/// `fillMode = "sensor"` — иначе мапинг игнорируется. Пишутся
/// `lastReadingAt` + `lastValue` чтобы UI мог быстро показать
/// «датчик жив», не ходя в Tuya API на каждый рендер.
model EquipmentSensorMapping {
  id            String          @id @default(cuid())
  equipmentId   String
  equipment     Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  templateId    String
  template      JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  /// Ключ из `template.fields[].key` (e.g. "temperature", "humidity")
  fieldKey      String
  /// Какую метрику с устройства брать. Сейчас поддержаны
  /// "temperature" / "humidity"; список расширяется по мере
  /// поддержки новых типов журналов.
  readingType   String
  lastReadingAt DateTime?
  /// Сериализованное значение (числа храним как строку — потом
  /// парсим по типу поля шаблона; так гибче если появятся булевые
  /// или enum-метрики).
  lastValue     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([equipmentId, templateId, fieldKey])
  @@index([templateId])
}

/// Long-form article for the public /blog. Platform-level (not org-scoped)
/// — edited by ROOT in /root/blog and displayed to any visitor. Body is
/// structured as a JSON-serialized array of typed blocks
/// (paragraph / heading / list / quote) so we never have to ship a Markdown
/// parser or sanitise arbitrary HTML.
model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  /// ArticleBlock[] — see src/lib/article-blocks.ts
  body        Json
  coverIcon   String?
  tags        String[]  @default([])
  readMinutes Int       @default(5)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
}

/// User-submitted feedback from the in-app "Оставить обратную связь" modal.
/// Stored without FK relations on purpose: we keep a snapshot of userId /
/// email / name / org at submission time so reports stay readable after a
/// user or organisation is later deleted.
model FeedbackReport {
  id               String   @id @default(cuid())
  userId           String?
  userEmail        String?
  userName         String?
  organizationId   String?
  organizationName String?
  /// "bug" | "suggestion"
  type             String
  message          String
  phone            String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

/// In-app notifications that surface state-drift hints ("add these new
/// employees to hygiene journal", etc). Each row is scoped to a recipient
/// user inside an organisation and carries a typed payload in `items`.
///
/// We persist read/dismiss on the same row so the «Прочитанные» tab can
/// list history without a separate join table. `items` is a JSON array of
/// small objects that the client renders as a checkbox list — the shape
/// is typed in src/lib/notifications.ts.
model Notification {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Domain tag — e.g. "staff.added.journal". Used to dedupe with `key`.
  kind           String
  /// Stable dedupe key (e.g. "staff.added.journal:<journalCode>") so
  /// repeated triggers merge items into the existing open notification
  /// instead of piling up duplicates.
  dedupeKey      String
  title          String
  /// Optional inline link target, e.g. "/journals/hygiene".
  linkHref       String?
  linkLabel      String?
  items          Json         @default("[]")
  /// Подзадачи (items.id), которые юзер уже отметил как прочитанные.
  /// При выдаче GET /api/notifications эти id фильтруются из items;
  /// если после фильтра items пустой — readAt автоматически выставится
  /// и нотификация перейдёт в «Прочитанные». Это даёт UX «прочитать
  /// одну подзадачу из десяти, не закрывая всю задачу».
  dismissedItemIds Json       @default("[]")
  readAt         DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, dismissedAt, readAt])
  @@index([organizationId])
}

model JournalObligation {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId     String
  template       JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  journalCode    String
  kind           String          @default("daily-journal")
  dateKey        DateTime
  status         String          @default("pending")
  targetPath     String
  source         String          @default("daily-journal-sync")
  dedupeKey      String
  openedAt       DateTime?
  completedAt    DateTime?
  /// Когда сотрудник «забрал» премиальное obligation через
  /// /api/journals/.../claim-bonus — заполняем эти поля атомарно
  /// одним UPDATE. Race-condition защита: уникальный constraint
  /// `claimedById` non-null + status="pending"-фильтр в WHERE.
  /// Используется только когда `template.bonusAmountKopecks > 0`.
  claimedById    String?
  claimedAt      DateTime?
  bonusEntry     BonusEntry?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, dateKey, status])
  @@index([organizationId, dateKey, status])
  @@index([templateId])
  @@index([claimedById])
}

model JournalTemplate {
  id                 String                     @id @default(cuid())
  code               String                     @unique
  name               String
  description        String?
  fields             Json
  isActive           Boolean                    @default(true)
  sortOrder          Int                        @default(0)
  isMandatorySanpin  Boolean                    @default(false)
  isMandatoryHaccp   Boolean                    @default(false)
  /// Распределение задач из этого журнала между сотрудниками:
  ///   "per-employee" — обязательство каждому подходящему сотруднику
  ///                    (гигиена, журнал здоровья — каждый за себя)
  ///   "single"       — одно обязательство на день: либо явно
  ///                    `defaultAssigneeId`, либо round-robin между
  ///                    подходящими сотрудниками
  ///   "sensor"       — заполняет IoT-датчик, людям не приходит
  ///                    (Фаза 2, пока заглушка)
  fillMode           String                     @default("per-employee")
  /// Используется только при `fillMode == "single"`. Если не null —
  /// обязательство всегда идёт этому пользователю; null → round-robin.
  defaultAssigneeId  String?
  defaultAssignee    User?                      @relation("DefaultAssignee", fields: [defaultAssigneeId], references: [id], onDelete: SetNull)
  /// Премиальная сумма (в копейках, чтобы не возиться с float-ами)
  /// за выполнение этого журнала. 0 — обычное обязательство без
  /// бонуса. Менеджер активирует через `/settings/journals` → у
  /// обязательств появляется кнопка «Взять с бонусом» (Фаза 3).
  bonusAmountKopecks Int                        @default(0)
  /// Тип задачи в TasksFlow:
  ///   "personal" — закреплено за одним сотрудником, закрывается один
  ///                раз за смену (hygiene, health_check, cleaning).
  ///   "shared"   — общая задача смены, доступна всем подходящим по
  ///                роли. Может быть заполнена N раз в день (event-log:
  ///                acceptance, finished_product, complaint_register).
  /// Default "personal" для back-compat. Settings UI в /settings/journals/[code]
  /// позволяет менеджеру переопределить для своей организации (см.
  /// OrgJournalScopeOverride если потребуется per-org override).
  taskScope          String                     @default("personal")
  /// Можно ли в TasksFlow нажать «Не требуется сегодня» вместо
  /// заполнения. False для критичных журналов (health_check —
  /// нельзя отказаться от проверки здоровья).
  allowNoEvents      Boolean                    @default(true)
  /// Список стандартных причин для closure без событий. JSON-массив
  /// строк. Менеджер редактирует в /settings/journals/[code].
  noEventsReasons    Json                       @default("[\"Поставок/событий нет\",\"Заведение закрыто\",\"Оборудование не в работе\",\"Выходной/праздничный день\"]")
  /// Можно ли вводить свободный текст причины в дополнение к списку.
  /// False — только из готового списка (стандартизация для отчётов).
  allowFreeTextReason Boolean                   @default(false)
  entries            JournalEntry[]
  documents          JournalDocument[]
  journalObligations JournalObligation[]
  positionAccess     JobPositionJournalAccess[]
  sensorMappings     EquipmentSensorMapping[]
  bonusEntries       BonusEntry[]
  closeEvents        JournalCloseEvent[]
  formFillTimings    FormFillTiming[]

  @@index([defaultAssigneeId])
}

/// Событие закрытия журнала за день — отдельное от обычных entry.
/// Создаётся когда сотрудник нажимает «Не требуется сегодня» / «Завершить
/// смену», или когда cron auto-close срабатывает в shiftEndHour.
///
/// Семантика kind:
///   "no-events"          — явное закрытие сотрудником с причиной
///                          (compliance ✅ зелёный)
///   "auto-closed-empty"  — cron закрыл по полуночи, никто не действовал
///                          (compliance 🟡 жёлтый — флаг халатности)
///   "closed-with-events" — сотрудник нажал «завершить смену» после
///                          N записей (compliance ✅ зелёный)
///
/// Reopen: если после закрытия случилось событие — сотрудник может
/// reopen'ить, тогда reopenedAt/reopenedByUserId заполняются. Запись
/// остаётся как audit trail (не удаляется).
model JournalCloseEvent {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId        String
  template          JournalTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  /// JournalDocument на которую относится closure. Null если журнал
  /// document-free (legacy field-based) — тогда date+template определяет.
  journalDocumentId String?
  journalDocument   JournalDocument? @relation(fields: [journalDocumentId], references: [id], onDelete: Cascade)
  /// UTC midnight того дня, который закрывается.
  date              DateTime
  kind              String
  /// Текст причины (либо из noEventsReasons-list, либо free-text).
  /// Пусто для "auto-closed-empty" и "closed-with-events".
  reason            String?
  closedByUserId    String?
  closedBy          User?            @relation("ClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  /// Заполняется когда юзер reopen'ит закрытие после факта события.
  reopenedAt        DateTime?
  reopenedByUserId  String?
  reopenedBy        User?            @relation("ReopenedBy", fields: [reopenedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())

  /// На один (template, date, org) — одно закрытие. Reopen не плодит
  /// новых записей, обновляет существующую.
  @@unique([organizationId, templateId, date])
  @@index([organizationId, date])
  @@index([templateId, date])
}

/// Per-org white-list: каким должностям разрешено получать
/// обязательства по этому шаблону. Если для шаблона нет ни одной
/// записи — считаем что разрешены все должности (back-compat).
model JobPositionJournalAccess {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobPositionId  String
  jobPosition    JobPosition     @relation(fields: [jobPositionId], references: [id], onDelete: Cascade)
  templateId     String
  template       JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())

  @@unique([jobPositionId, templateId])
  @@index([organizationId, templateId])
}

/// Запись о начислении бонуса за выполнение премиального журнала.
/// Создаётся когда сотрудник нажимает «Взять с бонусом» на
/// `JournalObligation` у которого `template.bonusAmountKopecks > 0`.
///
/// Жизненный цикл (Фаза 3):
///   1. claim — `UPDATE JournalObligation SET claimedById=$user
///      WHERE status='pending'` транзакционно. Кто первый прошёл —
///      тому BonusEntry со status="pending" создаётся.
///   2. submit — сотрудник прикрепил фото и нажал «Готово». EXIF-
///      timestamp проверяется (<5 минут), при успехе → status="approved".
///   3. reject (опционально) — менеджер ретроактивно может перевести
///      запись в "rejected" с причиной.
///
/// Один BonusEntry на одно obligation — `obligationId @@unique`.
model BonusEntry {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  obligationId   String            @unique
  obligation     JournalObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  templateId     String
  template       JournalTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Сумма зафиксирована в момент claim (template может потом сменить
  /// `bonusAmountKopecks`, и это не должно ретроактивно поменять
  /// уже начисленные премии).
  amountKopecks  Int
  /// "pending" | "approved" | "rejected"
  status         String            @default("pending")
  /// Ссылка на JournalEntryAttachment с фото-доказательством. Может
  /// быть null до момента submit.
  photoUrl       String?
  /// EXIF-timestamp с фото, если получили — для аудита анти-фрода.
  photoTakenAt   DateTime?
  /// Менеджер который ретроактивно отозвал бонус (status="rejected").
  rejectedById   String?
  rejectedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, status, createdAt])
  @@index([userId, status])
  @@index([templateId])
}

model Product {
