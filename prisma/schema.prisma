model ManagerScope {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managerId              String
  manager                User         @relation("ManagerScopes", fields: [managerId], references: [id], onDelete: Cascade)
  /// Visibility mode: "all" = sees everyone, "job_positions" = sees specific job positions, "specific_users" = sees specific users, "none" = sees no one
  viewMode               String       @default("all")
  /// Job position IDs visible when viewMode = "job_positions"
  viewJobPositionIds     String[]
  /// User IDs visible when viewMode = "specific_users"
  viewUserIds            String[]
  /// Journal template codes this manager can assign tasks for. Empty = all journals they have access to.
